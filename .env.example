# Copy this file to `.env` for the minimal local API/database setup.
# For cloud storage, scheduler auth, OAuth, media, billing, and other managed
# integrations, start from `.env.advanced.example` instead.

ORCHESTRA_RELOAD="True"
ORCHESTRA_PORT="8000"
ORCHESTRA_ENVIRONMENT="dev"

# Database
ORCHESTRA_DB_USER="orchestra"
ORCHESTRA_DB_PASS="orchestra"
ORCHESTRA_DB_BASE="orchestra"
ORCHESTRA_USE_CLOUD_SQL="false"

# Core auth / admin
ORCHESTRA_ADMIN_KEY="replace-me"
PROMETHEUS_METRICS_TOKEN="replace-me"
