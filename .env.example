ORCHESTRA_RELOAD="True"
ORCHESTRA_PORT="8000"
ORCHESTRA_ENVIRONMENT="dev"

# Database
ORCHESTRA_DB_USER="orchestra"
ORCHESTRA_DB_PASS="orchestra"
ORCHESTRA_DB_BASE="orchestra"
ORCHESTRA_USE_CLOUD_SQL="false"
# ORCHESTRA_CLOUD_SQL_INSTANCE="project:region:instance"

# Core auth / admin
ORCHESTRA_ADMIN_KEY="replace-me"
PROMETHEUS_METRICS_TOKEN="replace-me"
# CLOUD_SCHEDULER_SERVICE_ACCOUNT="scheduler@example.iam.gserviceaccount.com"

# Hosted platform URLs
UNIFY_CONSOLE_FRONTEND_URL="https://console.unify.ai/"
UNITY_COMMS_URL="http://127.0.0.1:8001"
UNITY_ADAPTERS_URL="http://127.0.0.1:8002"

# GCP / storage
GCP_PROJECT_ID="replace-me"
GCP_LOCATION="europe-west1"
ORCHESTRA_GCP_BUCKET_NAME="replace-me"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# Email / OAuth
# ONBOARDING_EMAIL="noreply@example.com"
# MAIL_SENDER_SERVICE_ACCOUNT_KEY="/path/to/mail-sender-service-account.json"
# GOOGLE_OAUTH_CLIENT_ID="replace-me"
# MICROSOFT_BYOD_CLIENT_ID="replace-me"
# OAUTH_STATE_SIGNING_KEY="replace-me"

# Voice / media
# CARTESIA_API_KEY="replace-me"
# CARTESIA_API_VERSION="replace-me"
# ELEVENLABS_API_KEY="replace-me"
# DEEPGRAM_API_KEY="replace-me"

# Security / CAPTCHA / MFA
# TURNSTILE_SECRET_KEY="replace-me"
# EMAIL_VERIFY_TOKEN_SECRET="replace-me"
# MFA_ENCRYPTION_KEY="replace-me"
# MFA_KMS_KEYRING="mfa"
