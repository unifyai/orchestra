[Unit]
Description=GCP Pub/Sub to train router
After=network.target

[Service]
ExecStart=/opt/train_router/venv/bin/python3 /opt/train_router/main.py
WorkingDirectory=/opt/train_router/
Restart=always
RestartSec=10
User=serviceuser
EnvironmentFile=/etc/environment

[Install]
WantedBy=multi-user.target
