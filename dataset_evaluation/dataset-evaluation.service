[Unit]
Description=GCP Pub/Sub to dataset evaluation
After=network.target

[Service]
ExecStart=/opt/dataset_evaluation/venv/bin/python3 /opt/dataset_evaluation/main.py
WorkingDirectory=/opt/dataset_evaluation/
Restart=always
RestartSec=10
User=serviceuser
EnvironmentFile=/etc/environment

[Install]
WantedBy=multi-user.target
